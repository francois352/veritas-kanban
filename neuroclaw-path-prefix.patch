# NeuroClaw Path Prefix Patches
# Fork-specific changes for deploying Veritas Kanban at /kanban/ sub-path.
#
# After upstream PR #189 (VITE_BASE_PATH support) merged 2026-03-09,
# most path prefix patches are now handled by upstream.
#
# Remaining fork patches (2 files):
# 1. Dockerfile — set default VITE_BASE_PATH=/kanban/ (upstream defaults to /)
#                 + add VITE_API_URL build arg
# 2. web/src/main.tsx — global fetch interceptor for raw fetch('/api/...') calls
#                       that bypass apiFetch(). Upstream PR #189 notes that
#                       some components still use raw fetch. This interceptor
#                       catches those and rewrites to /kanban/api/...
#
# Previously patched (now handled by upstream):
# - web/src/hooks/useWebSocket.ts (basePath for WS URL)
# - web/src/lib/api/helpers.ts (apiFetch prefix)
# - web/src/lib/config.ts (API_BASE with basePath)
# - web/src/components/settings/tabs/SecurityTab.tsx (auth reset URL)
# - web/vite.config.ts (base: VITE_BASE_PATH)
#
# To regenerate: git diff origin/main -- Dockerfile web/src/main.tsx

diff --git a/Dockerfile b/Dockerfile
--- a/Dockerfile
+++ b/Dockerfile
@@ -44,8 +44,10 @@ FROM build-shared AS build-web

 # Optional: deploy under a sub-path (e.g., /kanban/) behind a reverse proxy.
 # When set, all client-side routes and API calls are prefixed automatically.
-ARG VITE_BASE_PATH=/
+ARG VITE_BASE_PATH=/kanban/
+ARG VITE_API_URL=
 ENV VITE_BASE_PATH=${VITE_BASE_PATH}
+ENV VITE_API_URL=${VITE_API_URL}

 COPY web/ ./web/
 RUN pnpm --filter @veritas-kanban/web build

diff --git a/web/src/main.tsx b/web/src/main.tsx
--- a/web/src/main.tsx
+++ b/web/src/main.tsx
@@ -13,6 +13,26 @@ const queryClient = new QueryClient({
   },
 });

+// Rewrite /api/* fetch calls to include base path prefix (for reverse-proxy deployments)
+const _basePath = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
+if (_basePath && _basePath !== '') {
+  const _originalFetch = window.fetch;
+  window.fetch = function (input: RequestInfo | URL, init?: RequestInit) {
+    if (typeof input === 'string' && input.startsWith('/api/')) {
+      input = _basePath + input;
+    } else if (input instanceof Request && input.url.startsWith(window.location.origin + '/api/')) {
+      input = new Request(
+        input.url.replace(
+          window.location.origin + '/api/',
+          window.location.origin + _basePath + '/api/'
+        ),
+        input
+      );
+    }
+    return _originalFetch.call(window, input, init);
+  } as typeof fetch;
+}
+
 ReactDOM.createRoot(document.getElementById('root')!).render(
   <React.StrictMode>
     <QueryClientProvider client={queryClient}>
